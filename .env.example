# =====================================================================
# .env.example — Copie para .env e preencha com valores reais.
# NUNCA commitar o arquivo .env preenchido.
# Documentação detalhada: docs/04-Operacoes/Variaveis-de-Ambiente.md
# =====================================================================

# --- Telegram ---
# Obtido junto ao @BotFather. Ver docs/03-Integracoes/Telegram-BotFather.md
TELEGRAM_BOT_TOKEN=

# Modo de operação do bot: "polling" (dev) ou "webhook" (produção)
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=

# --- Banco de dados (Postgres recomendado) ---
DATABASE_URL=postgresql+psycopg://chatbot:chatbot@localhost:5432/chatbot

# --- Provedor de LLM ---
# Opções suportadas: "gemini" | "anthropic" | "openai" | "groq" | "ollama"
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=

# --- Embeddings (para RAG da base de conhecimento) ---
# Opções: "gemini" | "openai" | "sentence-transformers" (local)
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_API_KEY=

# --- Google APIs (Calendar + Docs + Drive) ---
# Ver docs/03-Integracoes/Google-Calendar.md e Google-Docs-Drive.md
GOOGLE_OAUTH_CLIENT_SECRETS_PATH=./client_secret.json
GOOGLE_OAUTH_TOKEN_STORE_PATH=./.google-tokens/
GOOGLE_DRIVE_KB_FOLDER_ID=

# --- Sistema acadêmico (placeholder — definir conforme a API real) ---
SISTEMA_ACADEMICO_BASE_URL=
SISTEMA_ACADEMICO_API_KEY=

# --- Observabilidade ---
LOG_LEVEL=INFO
LOG_FORMAT=json
